{
  "name": "elivatx-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace web\" \"npm run dev --workspace api\"",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run dev --workspace api",
    "build": "npm run build --workspace web && npm run build --workspace api",
    "lint": "npm run lint --workspace web",
    "start": "npm run start --workspace api"
  }
}
